{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EMPNO as short,",
				"          ENAME as string,",
				"          JOB as string,",
				"          MGR as short,",
				"          HIREDATE as string,",
				"          SAL as short,",
				"          COMM as short,",
				"          DEPTNO as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(taxsrc = SAL-(SAL*0.25),",
				"          sal_with_comm = SAL+COMM) ~> derivedColumn1"
			]
		}
	}
}